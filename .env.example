# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- Firebase (optional — leave empty to run 100% local) ---
#
# === Director + public live board setup ===
#
# 1) Firebase Console → Create project (or use existing).
# 2) Project settings → Your apps → Web app → copy config into the VITE_* vars below.
# 3) Authentication → Sign-in method → enable Google. Add support email.
# 4) Authentication → Settings → Authorized domains → add:
#      - localhost
#      - Your production host (e.g. myapp.vercel.app)
# 5) Firestore Database → Create database (start in production or test mode, then deploy rules).
# 6) Deploy firestore.rules from this repo:
#      firebase deploy --only firestore:rules
#    Rules summary: anyone can READ tournaments/teams/matches (for /live/...). Only the
#    creator (creatorId) can WRITE.
# 7) Firestore → Indexes: if "join by code" errors, create the suggested composite index
#    for collection `tournaments`, field `inviteCode` (usually single-field is enough).
# 8) Restart `npm run dev` after changing .env.
#
# Public live URL pattern (share with players):
#   https://YOUR_HOST/live/<tournamentDocumentId>
# Short form:
#   https://YOUR_HOST/live?code=<INVITE_CODE>
#
# VITE_FIREBASE_DISABLED=true

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional
VITE_FIREBASE_MEASUREMENT_ID=
# Omit or use (default)
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)
