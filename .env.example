# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Where the app is hosted (OAuth / links).
APP_URL="MY_APP_URL"

# --- Firebase (optional — leave empty to run 100% local) ---
# Copy this file to `.env` and paste values from Firebase console:
# Project settings → Your apps → Web app config.
# Also enable: Authentication → Google, Firestore (default DB), and authorized domains.
#
# VITE_FIREBASE_DISABLED=true

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optional
VITE_FIREBASE_MEASUREMENT_ID=
# Omit or use (default)
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)
