# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Where the app is hosted (OAuth / links).
APP_URL="MY_APP_URL"

# --- Firebase (optional — omit to run 100% local) ---
# Create a project at https://console.firebase.google.com
# → Project settings → Your apps → Web app → copy config.
# → Authentication → Sign-in method → enable Google.
# → Firestore → create database.
# → Add your dev URL under Authentication → Settings → Authorized domains.
#
# VITE_FIREBASE_DISABLED=true   # uncomment to ignore config and stay local

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Use "(default)" or your database id; AI Studio used a named DB — your new project is usually (default)
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)
